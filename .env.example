
# OpenAI API key — used server-side by /api/chatbot
# Never prefix with NEXT_PUBLIC_ — must stay server-side only
OPENAI_API_KEY="your_openai_api_key_here"

# App URL
APP_URL="https://www.sitecraf.com"

# Contact form email — used server-side by /api/contact
# Never prefix with NEXT_PUBLIC_ — must stay server-side only
CONTACT_FORM_EMAIL="your_email@domain.com"

# Cron job secret — used to authenticate Vercel Cron requests to /api/cron/blog-publisher
# Must match the CRON_SECRET set in Vercel dashboard environment variables
CRON_SECRET=your-random-secret-here

# Resend API key — used by cron route and blog approval emails
RESEND_API_KEY=your-resend-api-key-here

# SERPAPI key — used by blog automation for keyword research
SERPAPI_KEY=your-serpapi-key-here

# Blog approval email recipient
APPROVAL_TO_EMAIL=pramodvermabroken@gmail.com

# GitHub PAT — used by blog automation to create PRs
GITHUB_PAT=your-github-pat-here